{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "points": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "uid", "total"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "UserProfile" },
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "Order" },
      "description": "Orders"
    }
  }
}
