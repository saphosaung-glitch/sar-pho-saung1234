{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "points": { "type": "number" },
        "lastDeviceId": { "type": "string" },
        "authCode": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "uid", "total"]
    },
    "Product": {
      "title": "Product",
      "description": "Store product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mmName": { "type": "string" },
        "msName": { "type": "string" },
        "thName": { "type": "string" },
        "zhName": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "unit": { "type": "string" },
        "status": { "type": "string", "enum": ["published", "draft"] }
      },
      "required": ["id", "name", "price", "category", "image"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "key": { "type": "string" },
        "nameEn": { "type": "string" },
        "nameMm": { "type": "string" },
        "nameMs": { "type": "string" },
        "nameTh": { "type": "string" },
        "nameZh": { "type": "string" },
        "order": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "key", "nameEn", "nameMm"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "UserProfile" },
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "Order" },
      "description": "Orders"
    },
    "/products/{productId}": {
      "schema": { "$ref": "Product" },
      "description": "Store products"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "Category" },
      "description": "Product categories"
    }
  }
}
