rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: productId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - mmName: string (optional)
    //   - price: number (required)
    //   - category: string (required)
    //   - image: string (optional)
    //   - unit: string (optional)
    //   - isPremium: boolean (optional)
    //
    // Collection: orders
    // Document ID: orderId
    // Fields:
    //   - id: string (required)
    //   - roomNumber: string (required)
    //   - items: list (required)
    //   - total: number (required)
    //   - status: string (required)
    //   - customerName: string (required)
    //   - customerPhone: string (required)
    //   - paymentMethod: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - phone: string (required)
    //   - room: string (required)
    //   - points: number (required)
    //   - tier: string (required)
    //   - referredBy: string (optional)
    //   - lastActive: timestamp (optional)
    //
    // Collection: pointTransactions
    // Document ID: transactionId
    // Fields:
    //   - id: string (required)
    //   - uid: string (required)
    //   - type: string (required)
    //   - amount: number (required)
    //   - description: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: settings
    // Document ID: docId
    // Fields:
    //   - enabled: boolean (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "saphosaung@gmail.com" ||
         request.auth.token.email == "yelwinaung9981@gmail.com" ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    function isSuperAdmin() {
      return isAdmin() && 
        (request.auth.token.email == "saphosaung@gmail.com" ||
         request.auth.token.email == "yelwinaung9981@gmail.com" ||
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin');
    }

    function isValidOrder(data) {
      return data.customerPhone is string && data.customerPhone.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'packing', 'delivered', 'cancelled'];
    }

    function isValidUser(data) {
      return data.phone is string && data.phone.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.points is number && data.points >= 0;
    }

    function isValidCoupon(data) {
      return data.code is string && data.code.size() > 0 &&
             data.value is number && data.value > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) && request.resource.data.stock <= resource.data.get('stock', 0));
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.authUid == request.auth.uid); 
      allow create: if true;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.authUid == request.auth.uid && request.resource.data.status == 'cancelled' && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /users/{uid} {
      function isUserOwner() {
        return isAdmin() || 
               !exists(/databases/$(database)/documents/users/$(uid)) || 
               !('authUid' in get(/databases/$(database)/documents/users/$(uid)).data) ||
               (isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/users/$(uid)).data.authUid);
      }

      allow read: if isUserOwner();
      allow create: if true;
      allow update: if isUserOwner() && 
                    (!('points' in request.resource.data) || !('points' in resource.data) || request.resource.data.points <= resource.data.points);

      match /pointTransactions/{transactionId} {
        allow read: if isUserOwner();
        allow create: if isAdmin();
      }

      match /addresses/{addressId} {
        allow read, write: if isUserOwner();
      }
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promotionBanners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /deals/{dealId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bundles/{bundleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    match /broadcastNotifications/{notificationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }
  }
}
