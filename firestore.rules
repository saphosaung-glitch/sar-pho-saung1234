rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- PRIMITIVES ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "saphosaung@gmail.com" || 
        request.auth.token.email == "yelwinaung9981@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- USER RULES ---
    match /users/{phone} {
      allow read: if true;
      allow write: if true;

      match /addresses/{id} { allow read, write: if true; } 
      match /sessions/{id} { allow read, write, delete: if true; }
      match /pointTransactions/{id} { allow read, write: if true; }
      match /notifications/{id} { allow read, write, delete: if true; }
    }

    match /authToPhone/{authUid} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow create: if true; 
      allow read: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    match /products/{id} { 
      allow read: if true; 
      // Allow stock updates for order processing
      allow update: if isAdmin() || (incoming().diff(existing()).affectedKeys().hasOnly(['stock']));
      allow create, delete: if isAdmin();
    }
    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /coupons/{id} { allow read: if true; allow write: if isAdmin(); }
    match /deals/{id} { allow read: if true; allow write: if isAdmin(); }
    match /bundles/{id} { allow read: if true; allow write: if isAdmin(); }
    match /broadcastNotifications/{id} { allow read: if true; allow write: if isAdmin(); }
    match /promotionBanners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /admins/{id} { allow get: if isSignedIn(); allow list, write: if isAdmin(); }
    match /auditLogs/{id} { allow read, write: if isAdmin(); }
    match /test/{id} { allow read: if true; }
  }
}
